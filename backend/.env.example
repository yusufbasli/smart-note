# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/smartnote_db

# ── JWT ────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── App ────────────────────────────────────────────────────
APP_ENV=development
APP_TITLE=Smart-Note & Task Orchestrator API
APP_VERSION=0.1.0

# ── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed origins (used when APP_ENV != development).
# In development, all origins are allowed automatically.
ALLOWED_ORIGINS=http://localhost:3000
