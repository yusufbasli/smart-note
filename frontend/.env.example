# API base URL for frontend requests
# Web + local backend:
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Android emulator (if backend runs on your host machine):
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000/api/v1

# Physical device on same Wi-Fi (replace with your computer's LAN IP):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:8000/api/v1
